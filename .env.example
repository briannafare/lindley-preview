# GHL (GoHighLevel) — server-only. Never prefix with NEXT_PUBLIC_.
# Private Integration Token from: Settings → Private Integrations
GHL_PIT_TOKEN=
GHL_LOCATION_ID=pe2yBdfaVo406b3BaavZ

# Pipeline — populated after pipeline is created in GHL
# Pipeline name: "Lindley Team — Client Journey"
GHL_PIPELINE_ID=
GHL_STAGE_NEW_LEAD_ID=

# Custom field IDs — populated after fields are created in GHL
GHL_CF_LOAN_TYPE=
GHL_CF_LOAN_AMOUNT_RANGE=
GHL_CF_CREDIT_SCORE_RANGE=
GHL_CF_TIMELINE=
GHL_CF_NEIGHBORHOOD_INTEREST=
GHL_CF_LEAD_SOURCE_PAGE=
GHL_CF_CALCULATOR_HOME_PRICE=
GHL_CF_CALCULATOR_PAYMENT=

# Optional per-form webhook URLs (hybrid mode).
# If set for a given form type, /api/lead POSTs there instead of calling
# the REST API directly. Leave blank to use direct API.
GHL_WEBHOOK_SCHEDULE_CALL=
GHL_WEBHOOK_RATE_QUOTE=
GHL_WEBHOOK_CALCULATOR=
GHL_WEBHOOK_NEIGHBORHOOD=
GHL_WEBHOOK_GUIDE_DOWNLOAD=
GHL_WEBHOOK_DIVORCE_CONSULT=
GHL_WEBHOOK_APPLY_CLICK=
